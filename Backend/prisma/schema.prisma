generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model detail_pesanan {
  id_detail    Int      @id @default(autoincrement())
  id_pesanan   Int?
  id_produk    Int?
  jumlah       Int?
  harga_satuan Int?
  subtotal     Int?
  pesanan      pesanan? @relation(fields: [id_pesanan], references: [id_pesanan], onDelete: NoAction, onUpdate: NoAction)
  produk       produk?  @relation(fields: [id_produk], references: [id_produk], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model kategori {
  id_kategori   Int      @id @default(autoincrement())
  nama_kategori String?
  deskripsi     String?
  produk        produk[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model keranjang {
  id_keranjang Int     @id @default(autoincrement())
  id_user      Int?
  id_produk    Int?
  jumlah       Int?
  produk       produk? @relation(fields: [id_produk], references: [id_produk], onDelete: NoAction, onUpdate: NoAction)
  user         user?   @relation(fields: [id_user], references: [id_user], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model pembayaran {
  id_pembayaran Int       @id @default(autoincrement())
  id_pesanan    Int?
  metode_bayar  String?
  status_bayar  String?
  tanggal_bayar DateTime?
  bukti_bayar   String?
  pesanan       pesanan?  @relation(fields: [id_pesanan], references: [id_pesanan], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model pesanan {
  id_pesanan      Int              @id @default(autoincrement())
  id_user         Int?
  tanggal_pesanan DateTime?
  status_pesanan  String?
  detail_pesanan  detail_pesanan[]
  pembayaran      pembayaran[]
  user            user?            @relation(fields: [id_user], references: [id_user], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model produk {
  id_produk      Int              @id @default(autoincrement())
  id_kategori    Int?
  nama_produk    String?
  deskripsi      String?
  harga          Int?
  stok           Int?
  gambar         String?
  detail_pesanan detail_pesanan[]
  keranjang      keranjang[]
  kategori       kategori?        @relation(fields: [id_kategori], references: [id_kategori], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model user {
  id_user   Int         @id @default(autoincrement())
  nama      String?
  email     String?
  password  String?
  keranjang keranjang[]
  pesanan   pesanan[]
}
